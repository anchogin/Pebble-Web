# Required: copy this file to .env and change these before running.
PEBBLE_PASSWORD=your-password-here
PEBBLE_JWT_SECRET=your-random-secret-at-least-32-chars

# Optional
PEBBLE_DATA_DIR=/data
PEBBLE_PORT=8080
PEBBLE_SYNC_INTERVAL=10
PEBBLE_ENCRYPTION_KEY=

# 日志
PEBBLE_LOG_RETAIN_DAYS=1    # 只保留 1 天


# 1. 去 Google Cloud Console 获取凭据：
# - 打开： https://console.cloud.google.com/apis/credentials
# - 创建 OAuth 客户端 ID（Web 应用类型）
# - 授权重定向 URI 填： http://localhost:8080/api/v1/oauth/google/callback
# - 启用 Gmail API： https://console.cloud.google.com/apis/library/gmail.googleapis.com
# Google OAuth（在 Google Cloud Console 创建 Web 应用 OAuth 凭据后填入）
# PEBBLE_PUBLIC_URL 是通用设置里 Pebble 公开访问地址的初始/兜底值。
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
PEBBLE_PUBLIC_URL=http://localhost:8080
